# ─── TravelMate Backend — Copy to .env and fill in real values ──────────────
#
# Generate SECRET_KEY:  python -c "import secrets; print(secrets.token_hex(32))"
#
SECRET_KEY=change-this-to-a-random-64-char-hex-string

# AI Keys — at least one required. Gemini is tried first; Grok is the fallback.
# Gemini: https://aistudio.google.com/app/apikey  (free tier available)
# Grok:   https://console.x.ai/                   (xAI API)
GEMINI_API_KEY=your-gemini-api-key-here
GROK_API_KEY=your-grok-api-key-here

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@<host>:5432/postgres

# Token lifetime in minutes (1440 = 24h)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_BUCKET=photos
